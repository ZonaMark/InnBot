  "curso": {
    "id": "SCRATCH-EC0366",
    "titulo": "Scratch Pro: Pensamiento Computacional y Estándar EC0366",
    "descripcion": "Curso intensivo de programación por bloques enfocado en el desarrollo de lógica, algoritmos y creación de contenidos educativos digitales.",
    "edad": "10+ (Ideal para docentes y estudiantes)",
    "Objetivo1": "Apropiar: Dominar la lógica de programación por bloques y el entorno Scratch. Producir: Crear proyectos interactivos, juegos y simulaciones funcionales. Optimizar: Aplicar estructuras de control para resolver problemas complejos de forma eficiente.",
    "Objetivo2": "Que el participante desarrolle habilidades de pensamiento computacional mediante la metodología del estándar EC0366, logrando diseñar una solución digital integral que resuelva un problema de comunicación o aprendizaje.",
    "PerfilEgre": "✔ Programar algoritmos con estructuras condicionales y ciclos ✔ Gestionar variables y listas de datos ✔ Utilizar sensores y operadores para interactividad avanzada ✔ Desarrollar proyectos bajo estándares de calidad instruccional ✔ Implementar extensiones de IA y video.",
    "autor": "Marcos Moreno Márquez",
    "version": "1.0",
    "constancia": {
      "titulo": "Constancia de participación",
      "texto": "Se otorga la presente a quien concluye satisfactoriamente el curso 'Scratch Pro', demostrando competencias en lógica de programación y diseño de objetos de aprendizaje."
    }
  },

